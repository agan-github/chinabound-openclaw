{
  "skills": {
    "load": {
      "extraDirs": [
        "~/chinabound-openclaw/shared-skills"
      ],
      "watch": true,
      "watchDebounceMs": 250
    },
    "install": {
      "preferBrew": true,
      "nodeManager": "npm"
    }
  },
  "agents": {
    "defaults": {
      "skills": [
        "chinabound-shared-standards",
        "chinabound-routing-contracts",
        "chinabound-safety-gates",
        "chinabound-content-taxonomy"
      ],
      "sandbox": {
        "mode": "all",
        "backend": "docker",
        "scope": "agent",
        "workspaceAccess": "rw",
        "workspaceRoot": "~/.openclaw/sandboxes",
        "docker": {
          "image": "openclaw-sandbox:bookworm-slim",
          "containerPrefix": "chinabound-sbx-",
          "workdir": "/workspace",
          "readOnlyRoot": true,
          "tmpfs": [
            "/tmp",
            "/var/tmp",
            "/run"
          ],
          "network": "none"
        }
      },
      "tools": {
        "sessions": {
          "visibility": "tree"
        }
      },
      "model": {
        "primary": "openai/gpt-5.4",
        "fallbacks": [
          "anthropic/claude-sonnet-4-6"
        ]
      },
      "models": {
        "openai/gpt-5.4": {
          "alias": "GPT Primary"
        },
        "anthropic/claude-sonnet-4-6": {
          "alias": "Sonnet Fallback"
        }
      }
    },
    "list": [
      {
        "id": "chief-orchestrator",
        "default": true,
        "workspace": "~/chinabound-openclaw/agents/chief-orchestrator",
        "agentDir": "~/.openclaw/agents/chief-orchestrator/agent",
        "sandbox": {
          "mode": "all",
          "scope": "agent",
          "workspaceAccess": "rw",
          "docker": {
            "network": "none"
          }
        },
        "tools": {
          "profile": "coding",
          "allow": [
            "group:fs",
            "group:runtime",
            "group:messaging",
            "group:memory",
            "group:automation",
            "group:agents",
            "group:sessions"
          ],
          "deny": [
            "group:web",
            "browser"
          ]
        },
        "skills": [
          "chinabound-shared-standards",
          "chinabound-routing-contracts",
          "chinabound-safety-gates",
          "chinabound-content-taxonomy",
          "playbook"
        ],
        "subagents": {
          "allowAgents": [
            "*"
          ]
        }
      },
      {
        "id": "official-source-registry",
        "default": false,
        "workspace": "~/chinabound-openclaw/agents/official-source-registry",
        "agentDir": "~/.openclaw/agents/official-source-registry/agent",
        "sandbox": {
          "mode": "all",
          "scope": "agent",
          "workspaceAccess": "rw",
          "docker": {
            "network": "bridge"
          }
        },
        "tools": {
          "profile": "coding",
          "allow": [
            "group:fs",
            "group:runtime",
            "group:web"
          ],
          "deny": [
