  "bindings": [
    {
      "agentId": "chief-orchestrator",
      "match": {
        "channel": "telegram",
        "accountId": "default"
      }
    },
    {
      "agentId": "messaging",
      "match": {
        "channel": "telegram",
        "accountId": "alerts"
      }
    },
    {
      "agentId": "human-gatekeeper",
      "match": {
        "channel": "telegram",
        "accountId": "review"
      }
    }
  ],
  "identity": {
    "name": "ChinaBound",
    "theme": "official travel and culture operations system",
    "emoji": "🧭"
  },
  "gateway": {
    "reload": {
      "mode": "hybrid",
      "debounceMs": 300
    }
  },
  "auth": {
    "profiles": {
      "openai:work": {
        "provider": "openai",
        "mode": "api_key"
      },
      "anthropic:work": {
        "provider": "anthropic",
        "mode": "api_key"
      }
    },
    "order": {
      "openai": [
        "openai:work"
      ],
      "anthropic": [
        "anthropic:work"
      ]
    }
  },
  "cron": {
    "sessionRetention": "72h",
    "runLog": {
      "maxBytes": 10485760,
      "keepLines": 5000
    }
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "dmPolicy": "allowlist",
      "allowFrom": [
        "tg:REPLACE_OWNER_ID"
      ],
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "accounts": {
        "default": {
          "name": "ChinaBound main",
          "botToken": "REPLACE_MAIN_BOT_TOKEN"
        },
        "alerts": {
          "name": "ChinaBound alerts",
          "botToken": "REPLACE_ALERTS_BOT_TOKEN"
        },
        "review": {
          "name": "ChinaBound review",
          "botToken": "REPLACE_REVIEW_BOT_TOKEN"
        }
      }
    }
  }
}
