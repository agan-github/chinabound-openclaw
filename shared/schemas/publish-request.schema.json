{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Publish Request",
  "type": "object",
  "required": [
    "taskId",
    "channel",
    "contentType",
    "locale",
    "title",
    "status"
  ],
  "properties": {
    "taskId": {
      "type": "string"
    },
    "channel": {
      "type": "string"
    },
    "contentType": {
      "type": "string"
    },
    "locale": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "bodyMarkdown": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "dryRun": {
      "type": "boolean"
    }
  }
}
