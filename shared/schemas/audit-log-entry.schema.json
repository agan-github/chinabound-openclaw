{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AuditLogEntry",
  "type": "object",
  "required": [
    "entryId",
    "taskId",
    "agentId",
    "action",
    "timestamp"
  ],
  "properties": {
    "entryId": {
      "type": "string"
    },
    "taskId": {
      "type": "string"
    },
    "agentId": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision": {
      "type": "string"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}