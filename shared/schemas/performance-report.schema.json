{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PerformanceReport",
  "type": "object",
  "required": [
    "reportId",
    "window",
    "metrics",
    "recommendations"
  ],
  "properties": {
    "reportId": {
      "type": "string"
    },
    "window": {
      "type": "string"
    },
    "metrics": {
      "type": "object"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}