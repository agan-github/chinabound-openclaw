{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AssignmentBrief",
  "type": "object",
  "required": [
    "assignmentId",
    "goal",
    "audience",
    "format",
    "priority"
  ],
  "properties": {
    "assignmentId": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "audience": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "format": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "urgent"
      ]
    },
    "geoScope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "timeWindow": {
      "type": "object"
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "object"
    }
  }
}