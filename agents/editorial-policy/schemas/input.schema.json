{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Editorial Policy AgentInput",
  "type": "object",
  "required": [
    "taskId",
    "contentCandidates"
  ],
  "properties": {
    "taskId": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "urgent"
      ]
    },
    "contentCandidates": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "context": {
      "type": "object"
    },
    "upstreamRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "object"
    }
  }
}