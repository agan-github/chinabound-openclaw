{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Destination Story AgentOutput",
  "type": "object",
  "required": [
    "taskId",
    "agentId",
    "status",
    "storyDrafts"
  ],
  "properties": {
    "taskId": {
      "type": "string"
    },
    "agentId": {
      "const": "destination-story"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "needs_review",
        "blocked",
        "error"
      ]
    },
    "storyDrafts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "handoffs": {
      "type": "array",
      "items": {
        "$ref": "../../../shared/schemas/agent-handoff.schema.json"
      }
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "green",
        "yellow",
        "red"
      ]
    },
    "summary": {
      "type": "string"
    }
  }
}